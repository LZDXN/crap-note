# Crap Notes — local environment template.
# Copy this file to `.env.local` and fill in real values.
# .env.local is git-ignored; this file (.env.local.example) is committed as a template.

# --- Admin auth (required to enable login + private uploads) ---
# Without these three set, the app runs with auth disabled and uploads are open
# to anyone who can reach the server. Only do that on a machine nobody else can reach.

ADMIN_USERNAME="ADMIN"

# Long random string. Generate with:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
ADMIN_PASSWORD=""

# Different long random string used as the HMAC key for session cookies.
# Rotating this invalidates all existing sessions. Generate with:
#   node -e "console.log(require('node:crypto').randomBytes(48).toString('base64url'))"
ADMIN_SESSION_SECRET=""

# --- Storage backend (optional) ---
# If BLOB_READ_WRITE_TOKEN is set, the app uses Vercel Blob (private access).
# Otherwise it falls back to the local filesystem (./data).
# Pull this from Vercel with: npx vercel env pull .env.local
# BLOB_READ_WRITE_TOKEN=""
